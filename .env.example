# pREST — Database connection secrets
# ===========================================
# Copy this file to .env, fill in your credentials, and pREST will pick
# them up at startup. Values in the actual environment (export / Docker /
# k8s) take precedence over the file.
#
#   cp .env.example .env
#
# ---------------------------------------------------------------------------

# Primary database connection (overrides [pg].url in prest.toml)
# DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# Named extra connections  (override [[pg.urls]] entries by name)
# PREST_PG_URL_YARSEW="postgresql://user:pass@db.yarsew.example.com:5432/postgres?sslmode=require"
# PREST_PG_URL_OGMAMI="postgresql://user:pass@db.ogmami.example.com:5432/postgres?sslmode=require"
# PREST_PG_URL_LOBEHUB="postgresql://user:pass@db.lobehub.example.com:5432/postgres?sslmode=require"
